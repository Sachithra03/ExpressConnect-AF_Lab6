<h1>Add New Post</h1>

<form action="/posts/add" method="POST">
  <label>Title</label>
  <input type="text" name="title" required>

  <label>Content</label>
  <textarea name="content" rows="5" required></textarea>

  <label>Author</label>
  <input type="text" name="author" required>

  <button type="submit">Add Post</button>
</form>