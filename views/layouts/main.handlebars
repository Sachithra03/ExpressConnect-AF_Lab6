<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f4;
      margin: 30px;
    }

    .container {
      max-width: 800px;
      margin: auto;
      background: white;
      padding: 20px;
      border-radius: 10px;
    }

    a {
      margin-right: 15px;
      text-decoration: none;
      color: blue;
    }

    input, textarea {
      width: 100%;
      padding: 10px;
      margin-top: 8px;
      margin-bottom: 12px;
    }

    button {
      padding: 10px 15px;
      cursor: pointer;
    }

    .post {
      border: 1px solid #ddd;
      padding: 12px;
      margin-bottom: 12px;
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <div class="container">
    <a href="/">Home</a>
    <a href="/posts/view">View Posts</a>
    {{#if currentUser}}
      <a href="/posts/add">Add Post</a>
      <form action="/logout" method="POST" style="display:inline;">
        <button type="submit">Logout ({{currentUser.username}})</button>
      </form>
    {{else}}
      <a href="/login">Login</a>
    {{/if}}
    <hr>
    {{{body}}}
  </div>
</body>
</html>